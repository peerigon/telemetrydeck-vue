{
  "name": "@peerigon/telemetrydeck-vue",
  "version": "0.0.0-semantically-released",
  "private": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/peerigon/telemetrydeck-vue.git"
  },
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "default": "./dist/index.mjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/types/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "rollup -c",
    "postbuild": "npm run test:exports",
    "dev": "vite",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint src",
    "prepack": "npm run build",
    "preview": "vite preview",
    "release": "semantic-release",
    "size": "size-limit",
    "test": "vitest --coverage",
    "test:exports": "node tests/exports/import.mjs && node tests/exports/require.cjs && tsc --noEmit -p tests/exports/tsconfig.json",
    "test:pack": "node tests/pack/contents.mjs",
    "typecheck": "vue-tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.build.json"
  },
  "dependencies": {
    "@telemetrydeck/sdk": "^2.0.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@peerigon/configs": "^18.1.2",
    "@rollup/plugin-commonjs": "^29.0.3",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-replace": "^6.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@semantic-release/git": "^10.0.1",
    "@size-limit/preset-small-lib": "^12.1.0",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/jsdom": "^28.0.3",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.1.9",
    "@vue/test-utils": "^2.4.11",
    "eslint": "^9.39.4",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.1",
    "rollup": "^4.62.2",
    "rollup-plugin-delete": "^3.0.2",
    "rollup-plugin-peer-deps-external": "^2.2.4",
    "rollup-plugin-typescript2": "^0.37.0",
    "semantic-release": "^25.0.5",
    "size-limit": "^12.1.0",
    "typescript": ">=6.0.3 <6.1.0",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.0",
    "vitest": "^4.1.9",
    "vue": "^3.5.39",
    "vue-eslint-parser": "^10.4.1",
    "vue-tsc": "^3.3.5"
  },
  "peerDependencies": {
    "vue": "^3.0.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "size-limit": [
    {
      "path": "dist/index.mjs",
      "limit": "10 kB"
    },
    {
      "path": "dist/index.cjs",
      "limit": "10 kB"
    }
  ]
}
